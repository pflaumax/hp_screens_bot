[Unit]
Description=Harry Potter Screengrab Bluesky Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/harry-potter-screengrab-bot
Environment="PATH=/home/pi/harry-potter-screengrab-bot/venv/bin"
EnvironmentFile=/home/pi/harry-potter-screengrab-bot/.env
ExecStart=/home/pi/harry-potter-screengrab-bot/venv/bin/python main.py
Restart=always
RestartSec=15
StandardOutput=append:/home/pi/harry-potter-screengrab-bot/logs/systemd.log
StandardError=append:/home/pi/harry-potter-screengrab-bot/logs/systemd-error.log

[Install]
WantedBy=multi-user.target
